# GitHub OAuth App
GITHUB_ID=your_github_oauth_app_id
GITHUB_SECRET=your_github_oauth_app_secret

# GitHub org that gets access (leave empty to allow anyone)
ALLOWED_ORG=your-org-name

# GitHub token (for checking org membership + reading issues/PRs)
GITHUB_TOKEN=ghp_xxx

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Docker volume name for shared Claude auth (auto-set by docker-compose)
CLAUDE_AUTH_VOLUME=agentbox_claude-auth

# No ANTHROPIC_API_KEY needed — uses Claude subscription via auth container
